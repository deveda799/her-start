# Her Start - 她来开局 比赛版环境变量

# 运行模式
APP_MODE=competition
REQUIRE_LOGIN=false
SHOW_USAGE_LIMIT=false

# 积分与动态追问
ENABLE_POINTS=true
ENABLE_AI_FOLLOWUP=true

# 静默限流（后台不显示给用户）
GLOBAL_DAILY_AI_LIMIT=300
IP_HOURLY_AI_LIMIT=10

# AI 服务（不配置则进入演示模式）
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash

# 站点地址（用于品牌报告署名）
NEXT_PUBLIC_SITE_URL=https://her-start.example.com

# 部署节点标识（codebanana / tencent）
NEXT_PUBLIC_DEPLOY_TARGET=codebanana
